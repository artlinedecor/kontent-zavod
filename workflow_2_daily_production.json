            "Status": "Video_Ready",
            "Caption_UZ": "={{ $json.caption }}",
            "Hashtags": "={{ $json.hashtags }}"
          }
        },
        "options": {}
      },
      "id": "update-video-ready",
      "name": "💾 Update: Video Ready",
      "type": "n8n-nodes-base.airtable",
