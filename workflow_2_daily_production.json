      "id": "check-done",
      "name": "✅ Video Done?",
      "type": "n8n-nodes-base.if",
      "typeVersion": 2,
      "position": [2640, 300]
    },
    {
      "parameters": {
        "jsCode": "const pollResponse = $input.first().json;\nconst prevData = $('📎 Extract Operation ID').first().json;\nconst pollCount = (prevData.poll_count || 0) + 1;\n\nif (pollCount >= prevData.max_polls) {\n  throw new Error(`Veo 3.1 timed out after ${pollCount} polls (${pollCount * 15}s)`);\n}\n\nreturn [{\n  json: {\n    operation_name: prevData.operation_name,\n    poll_count: pollCount,\n    max_polls: prevData.max_polls,\n    record_id: prevData.record_id\n  }\n}];"
      },
      "id": "increment-poll",
      "name": "🔄 Retry Poll",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [2860, 500]
    },
    {
      "parameters": {
        "jsCode": "const pollResponse = $input.first().json;\nlet videoBase64;\n\ntry {\n  videoBase64 = pollResponse.response.generatedVideos[0].video.videoBytes\n    || pollResponse.response.predictions[0].bytesBase64Encoded;\n} catch(e) {\n  throw new Error('Failed to extract video: ' + JSON.stringify(pollResponse).substring(0, 500));\n}\n\nconst recordId = $('📎 Extract Operation ID').first().json.record_id;\n\nreturn [{\n  json: {\n    video_generated: true,\n    record_id: recordId\n  },\n  binary: {\n    video: {\n      data: videoBase64,\n      mimeType: 'video/mp4',\n      fileName: `artline_video_${new Date().toISOString().split('T')[0]}_${Date.now()}.mp4`\n    }\n  }\n}];"
      },
      "id": "process-video",
      "name": "🎥 Process Video Binary",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [2860, 200]
    },
    {
      "parameters": {
        "method": "POST",
        "url": "https://generativelanguage.googleapis.com/v1beta/models/gemini-2.5-flash:generateContent",
        "authentication": "genericCredentialType",
        "genericAuthType": "httpQueryAuth",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            { "name": "Content-Type", "value": "application/json" }
          ]
        },
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={\n  \"contents\": [{\n    \"parts\": [{\n      \"text\": \"SYSTEM: Sen Artline Decor uchun Daho Darajasidagi Kopirayter, Neyromarketolog va Psixologsan. Yozgan har bir matning (caption) mijozlarni o'ziga jalb qilishi, ishonchini qozonishi va SOTUVGA (DM/Call) undashi shart.\\n\\nBREND VA AUDITORIYA:\\n- Ovoz (Voice): Premium, ekspert, ishonchli, elit.\\n- Auditoriya: O'zbekistondagi uy egalari, kotej qurayotganlar, arxitektorlar.\\n\\nKOPIRAYTING (AIDA + PAS STRATEGIYASI):\\n1. HOOK (Ilgak): Birinchi qator shok qiluvchi, qiziqtiruvchi yoki kuchli og'riq nuqtasini bosuvchi savol bo'lishi kerak. Emojidan foydalan.\\n2. AGITATE (Og'riqni kuchaytirish): Arzon fasad materiallarining oqibatlari (yoriqlar, issiqlik yo'qotish, xunuk ko'rinish).\\n3. SOLUTION (Yechim): Artline Decor termopanellari va elit dizaynlari bu muammoni qanday qilib bir umrga hal qiladi.\\n4. SOCIAL PROOF & STATUS: Qo'shnilar havas qiladigan fasad, uzoq yillik kafolat, status ko'rsatkichi.\\n5. FOMO & CTA (Harakatga chorlov): Kamchilik hissini (FOMO) yarat (Masalan: 'Joriy mavsum uchun o'lchov olish o'rinlari cheklangan'). Directga (DM) '+' yozishga yoki qo'ng'iroq qilishga majbur qil.\\n\\nHASHTAGLAR (Mutlaqo ilmiy SEO): 20 ta hashtag. 5 ta brand (#ArtlineDecor #ArtlineUz), 10 ta muayyan (#termopanel #fasaddizayn #kotej #qurilish), 5 ta lokatsiya (#Toshkent #Uzbekistan).\\n\\nMAVZU: {{ $('📋 Fetch Today\\'s Task').item.json.Topic_UZ }}\\nUSLUB: {{ $('📋 Fetch Today\\'s Task').item.json.Visual_Style }}\\n\\nCHIQISh: FAQAT JSON:\\n{\\\"caption\\\": \\\"Mukammal O'zbekcha matn\\\", \\\"hashtags\\\": \\\"#tag1 #tag2...\\\", \\\"hook_line\\\": \\\"Birinchi qator...\\\"}\"\n    }]\n  }],\n  \"generationConfig\": {\n    \"temperature\": 0.8,\n    \"responseMimeType\": \"application/json\"\n  }\n}",
        "options": { "timeout": 30000 }
      },
      "id": "generate-caption",
      "name": "✍️ AI Caption Generator",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [3080, 200],
      "credentials": {
        "httpQueryAuth": {
          "id": "JSyk5hMaoWqU3UDn",
          "name": "Google API Key"
        }
      }
    },
    {
      "parameters": {
        "jsCode": "const captionResponse = $input.first().json;\nconst videoData = $('🎥 Process Video Binary').first();\nconst taskData = $('📋 Fetch Today\\'s Task').first().json;\n\nlet caption;\ntry {\n  const text = captionResponse.candidates[0].content.parts[0].text;\n  caption = JSON.parse(text);\n} catch(e) {\n  caption = {\n    caption: `🏗️ ${taskData.Topic_UZ}\\n\\nArtline Decor — premium fasad yechimlari\\n\\n📞 Biz bilan bog'laning!`,\n    hashtags: '#ArtlineDecor #termopanel #fasad #Toshkent #arxitektura',\n    hook_line: `🏗️ ${taskData.Topic_UZ}`\n  };\n}\n\nreturn [{\n  json: {\n    record_id: videoData.json.record_id,\n    caption: caption.caption,\n    hashtags: caption.hashtags,\n    hook_line: caption.hook_line,\n    topic: taskData.Topic_UZ,\n    date: taskData.Date\n  },\n  binary: videoData.binary\n}];"
      },
      "id": "prepare-delivery",
      "name": "📦 Prepare for Delivery",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [3300, 200]
    },
    {
      "parameters": {
        "operation": "update",
        "application": "appfv9xstsRzEOjTu",
        "table": "Content_Plan",
