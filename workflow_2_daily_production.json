    {
      "parameters": {
        "method": "POST",
        "url": "https://generativelanguage.googleapis.com/v1beta/models/imagen-3.0-generate-001:generateImages",
        "authentication": "genericCredentialType",
        "genericAuthType": "httpQueryAuth",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            { "name": "Content-Type", "value": "application/json" }
          ]
        },
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={\n  \"instances\": [\n    {\n      \"prompt\": \"{{ $('📋 Fetch Today\\'s Task').item.json.Image_Prompt }}\"\n    }\n  ],\n  \"parameters\": {\n    \"sampleCount\": 1,\n    \"aspectRatio\": \"9:16\",\n    \"negativePrompt\": \"floral patterns, ornate decorations, flowers, curved ornaments, baroque, rococo, text, watermark, blurry, low quality\"\n  }\n}",
        "options": {
          "timeout": 120000,
          "response": {
            "response": {
              "responseFormat": "json"
            }
          }
        }
      },
      "id": "imagen-generate",
      "name": "🎨 Imagen 3: Generate Image",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [1100, 300],
      "credentials": {
        "httpQueryAuth": {
          "id": "JSyk5hMaoWqU3UDn",
          "name": "Google API Key"
        }
      },
      "onError": "continueErrorOutput"
    },
    {
      "parameters": {
        "jsCode": "const response = $input.first().json;\n\nlet imageBase64;\ntry {\n  // Imagen 3 returns base64 encoded image\n  imageBase64 = response.predictions[0].bytesBase64Encoded \n    || response.generatedImages[0].image.imageBytes;\n} catch(e) {\n  throw new Error('Failed to extract image from Imagen 3 response: ' + JSON.stringify(response).substring(0, 500));\n}\n\n// Convert base64 to binary\nconst binaryData = Buffer.from(imageBase64, 'base64');\n\nreturn [{\n  json: {\n    image_generated: true,\n    image_size: binaryData.length,\n    record_id: $('📋 Fetch Today\\'s Task').first().json.id\n  },\n  binary: {\n    image: {\n      data: imageBase64,\n      mimeType: 'image/png',\n      fileName: `artline_${new Date().toISOString().split('T')[0]}_${Date.now()}.png`\n    }\n  }\n}];"
      },
      "id": "process-image",
      "name": "🖼️ Process Image Binary",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [1320, 300]
    },
    {
      "parameters": {
        "operation": "update",
        "application": "appfv9xstsRzEOjTu",
        "table": "Content_Plan",
        "id": "={{ $json.record_id }}",
        "columns": {
          "mappingMode": "defineBelow",
          "value": {
            "Status": "Image_Ready"
          }
        },
        "options": {}
      },
      "id": "update-image-status",
      "name": "💾 Update: Image Ready",
      "type": "n8n-nodes-base.airtable",
      "typeVersion": 2.1,
      "position": [1540, 300],
      "credentials": {
        "airtableTokenApi": {
          "id": "mmrJiYmHvNKROxEr",
          "name": "Airtable Personal Access Token"
        }
      }
    },
    {
      "parameters": {
        "method": "POST",
        "url": "https://generativelanguage.googleapis.com/v1beta/models/veo-3.1-generate-preview:predictLongRunning",
        "authentication": "genericCredentialType",
        "genericAuthType": "httpQueryAuth",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            { "name": "Content-Type", "value": "application/json" }
          ]
        },
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={\n  \"instances\": [\n    {\n      \"prompt\": \"{{ $('📋 Fetch Today\\'s Task').item.json.Video_Prompt }}\"\n    }\n  ],\n  \"parameters\": {\n    \"durationSeconds\": 8,\n    \"aspectRatio\": \"9:16\",\n    \"resolution\": \"720p\",\n    \"sampleCount\": 1\n  }\n}",
        "options": {
          "timeout": 60000,
          "response": {
            "response": {
              "responseFormat": "json"
            }
          }
        }
      },
      "id": "veo-initiate",
      "name": "🎬 Veo 3.1: Start Video Gen",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [1760, 300],
      "credentials": {
        "httpQueryAuth": {
          "id": "JSyk5hMaoWqU3UDn",
          "name": "Google API Key"
        }
      },
      "onError": "continueErrorOutput"
    },
    {
      "parameters": {
        "jsCode": "const response = $input.first().json;\nconst operationName = response.name;\n\nif (!operationName) {\n  throw new Error('Veo 3.1 did not return an operation name: ' + JSON.stringify(response).substring(0, 300));\n}\n\nreturn [{\n  json: {\n    operation_name: operationName,\n    poll_count: 0,\n    max_polls: 40,\n    record_id: $('📋 Fetch Today\\'s Task').first().json.id\n  }\n}];"
      },
      "id": "extract-operation",
      "name": "📎 Extract Operation ID",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [1980, 300]
    },
    {
      "parameters": {
        "amount": 15,
        "unit": "seconds"
      },
      "id": "wait-poll",
      "name": "⏳ Wait 15s",
      "type": "n8n-nodes-base.wait",
      "typeVersion": 1.1,
      "position": [2200, 300],
      "webhookId": "veo-poll-wait"
    },
    {
      "parameters": {
        "method": "GET",
        "url": "=https://generativelanguage.googleapis.com/v1beta/{{ $json.operation_name }}",
        "authentication": "genericCredentialType",
        "genericAuthType": "httpQueryAuth",
        "options": {
          "timeout": 30000,
          "response": {
            "response": {
              "responseFormat": "json"
            }
          }
        }
      },
      "id": "veo-poll",
      "name": "🔍 Poll Veo Status",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [2420, 300],
      "credentials": {
        "httpQueryAuth": {
          "id": "JSyk5hMaoWqU3UDn",
          "name": "Google API Key"
        }
      }
    },
    {
      "parameters": {
        "conditions": {
          "options": { "caseSensitive": true, "leftValue": "", "typeValidation": "strict" },
          "conditions": [
            {
              "id": "is-done",
              "leftValue": "={{ $json.done }}",
              "rightValue": true,
              "operator": { "type": "boolean", "operation": "true" }
            }
