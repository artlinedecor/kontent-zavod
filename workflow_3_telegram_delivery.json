        }
      }
    },
    {
      "parameters": {
        "operation": "sendMessage",
        "chatId": "8266195913",
        "text": "=⚠️ *Delivery XATOLIK*\n\n❌ Kontent yetkazishda xatolik yuz berdi\n📝 Record: {{ $('✍️ Format Telegram Message').item.json.record_id }}\n\nn8n dashboardni tekshiring.",
        "additionalFields": { "parse_mode": "Markdown" }
      },
      "id": "error-delivery",
      "name": "⚠️ Error Notification",
      "type": "n8n-nodes-base.telegram",
      "typeVersion": 1.2,
      "position": [1320, 600],
      "credentials": {
        "telegramApi": {
          "id": "jOU7JKhtcHMviF47",
          "name": "Telegram Bot"
        }
      }
    }
  ],
