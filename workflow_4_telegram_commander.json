      "parameters": {
        "operation": "search",
        "application": "appfv9xstsRzEOjTu",
        "table": "Analytics_Log",
        "returnAll": true,
        "options": {"sort": {"property": [{"field": "Date", "direction": "desc"}]}}
      },
      "id": "get-stats",
      "name": "📊 Get Stats",
      "type": "n8n-nodes-base.airtable",
      "typeVersion": 2.1,
      "position": [900, 400],
      "credentials": {"airtableTokenApi": {"id": "mmrJiYmHvNKROxEr", "name": "Airtable Personal Access Token"}}
