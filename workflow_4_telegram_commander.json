{
  "name": "Telegram Commander — Smart Content Factory",
  "nodes": [
    {
      "parameters": {
        "updates": ["message", "callback_query"]
      },
      "id": "tg-trigger",
      "name": "📱 Telegram Trigger",
      "type": "n8n-nodes-base.telegramTrigger",
      "typeVersion": 1.1,
      "position": [200, 400],
      "credentials": {
        "telegramApi": {
          "id": "jOU7JKhtcHMviF47",
          "name": "Telegram Bot"
        }
      }
    },
    {
      "parameters": {
        "jsCode": "const update = $input.first().json;\nlet cmd = 'help', arg = '', chatId = '8266195913', cbId = '';\n\nif (update.message) {\n  chatId = String(update.message.chat.id);\n  const t = (update.message.text || '').trim();\n  if (t.startsWith('/plan')) cmd = 'plan';\n  else if (t.startsWith('/rasm')) { cmd = 'rasm'; arg = t.split(/\\s+/)[1] || '1'; }\n  else if (t.startsWith('/video')) { cmd = 'video'; arg = t.split(/\\s+/)[1] || '1'; }\n  else if (t.startsWith('/bugun')) cmd = 'bugun';\n  else if (t.startsWith('/stats')) cmd = 'stats';\n  else if (t.startsWith('/start') || t.startsWith('/help')) cmd = 'help';\n  else cmd = 'help';\n} else if (update.callback_query) {\n  chatId = String(update.callback_query.message.chat.id);\n  cbId = update.callback_query.id;\n  const d = update.callback_query.data || '';\n  if (d.startsWith('gen_image_')) { cmd = 'do_image'; arg = d.replace('gen_image_',''); }\n  else if (d.startsWith('gen_video_')) { cmd = 'do_video'; arg = d.replace('gen_video_',''); }\n  else if (d === 'cancel') cmd = 'cancel';\n}\nreturn [{ json: { cmd, arg, chatId, cbId } }];"
      },
      "id": "parse-cmd",
      "name": "🧠 Parse Command",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [420, 400]
    },
    {
      "parameters": {
        "rules": {
          "values": [
            {"conditions":{"conditions":[{"leftValue":"={{ $json.cmd }}","rightValue":"help","operator":{"type":"string","operation":"equals"}}]},"renameOutput":true,"outputKey":"help"},
            {"conditions":{"conditions":[{"leftValue":"={{ $json.cmd }}","rightValue":"bugun","operator":{"type":"string","operation":"equals"}}]},"renameOutput":true,"outputKey":"bugun"},
            {"conditions":{"conditions":[{"leftValue":"={{ $json.cmd }}","rightValue":"stats","operator":{"type":"string","operation":"equals"}}]},"renameOutput":true,"outputKey":"stats"},
            {"conditions":{"conditions":[{"leftValue":"={{ $json.cmd }}","rightValue":"rasm","operator":{"type":"string","operation":"equals"}}]},"renameOutput":true,"outputKey":"rasm"},
            {"conditions":{"conditions":[{"leftValue":"={{ $json.cmd }}","rightValue":"video","operator":{"type":"string","operation":"equals"}}]},"renameOutput":true,"outputKey":"video"},
            {"conditions":{"conditions":[{"leftValue":"={{ $json.cmd }}","rightValue":"do_image","operator":{"type":"string","operation":"equals"}}]},"renameOutput":true,"outputKey":"do_image"},
            {"conditions":{"conditions":[{"leftValue":"={{ $json.cmd }}","rightValue":"do_video","operator":{"type":"string","operation":"equals"}}]},"renameOutput":true,"outputKey":"do_video"},
            {"conditions":{"conditions":[{"leftValue":"={{ $json.cmd }}","rightValue":"cancel","operator":{"type":"string","operation":"equals"}}]},"renameOutput":true,"outputKey":"cancel"},
            {"conditions":{"conditions":[{"leftValue":"={{ $json.cmd }}","rightValue":"plan","operator":{"type":"string","operation":"equals"}}]},"renameOutput":true,"outputKey":"plan"}
          ]
        },
        "options": {"fallbackOutput": "extra"}
      },
      "id": "router",
      "name": "🔀 Router",
      "type": "n8n-nodes-base.switch",
      "typeVersion": 3,
      "position": [640, 400]
    },
    {
      "parameters": {
        "operation": "sendMessage",
        "chatId": "={{ $('🧠 Parse Command').item.json.chatId }}",
        "text": "🏭 *SMART CONTENT FACTORY*\n\n📋 Buyruqlar:\n\n/bugun — Bugungi kontent rejasi\n/plan — Haftalik reja tuzish (AI)\n/rasm 3 — 3-kun uchun rasm yaratish\n/video 3 — 3-kun uchun video yaratish\n/stats — Statistika\n/help — Yordam\n\n🎯 Maqsad: Ohvat, obunachi va savdoni oshirish uchun strategik kontent!",
        "additionalFields": {"parse_mode": "Markdown"}
      },
      "id": "send-help",
      "name": "📖 Help",
      "type": "n8n-nodes-base.telegram",
      "typeVersion": 1.2,
      "position": [900, 100],
      "credentials": {"telegramApi": {"id": "jOU7JKhtcHMviF47", "name": "Telegram Bot"}}
    },
    {
      "parameters": {
        "operation": "search",
        "application": "appfv9xstsRzEOjTu",
        "table": "Content_Plan",
        "returnAll": false,
        "limit": 10,
        "options": {"filterByFormula": "=IS_SAME({Date}, TODAY(), 'day')"}
      },
      "id": "get-today",
      "name": "📋 Get Today",
      "type": "n8n-nodes-base.airtable",
      "typeVersion": 2.1,
      "position": [900, 250],
      "credentials": {"airtableTokenApi": {"id": "mmrJiYmHvNKROxEr", "name": "Airtable Personal Access Token"}}
    },
    {
      "parameters": {
        "jsCode": "const items = $input.all();\nconst chatId = $('🧠 Parse Command').first().json.chatId;\nif (!items.length || !items[0].json.id) {\n  return [{ json: { chatId, text: '📋 Bugun uchun kontent rejasi yo\\'q.\\n\\n/plan buyrug\\'i bilan yangi reja tuzing!' } }];\n}\nconst lines = items.map(i => {\n  const d = i.json;\n  const status = d.Status === 'Pending' ? '⏳' : d.Status === 'Processing' ? '🔄' : d.Status === 'Video_Ready' ? '✅' : d.Status === 'Delivered' ? '📱' : '📋';\n  return `${status} *${d.Slot || ''}*: ${d.Topic_UZ || d.Topic_EN || 'Mavzu'}\\nUslub: ${d.Visual_Style || '-'} | ${d.Content_Type || '-'}`;\n}).join('\\n\\n');\nreturn [{ json: { chatId, text: `📅 *BUGUNGI KONTENT REJA*\\n\\n${lines}\\n\\n💡 /rasm N yoki /video N bilan yarating!` } }];"
      },
      "id": "fmt-today",
      "name": "✏️ Format Today",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [1120, 250]
    },
    {
      "parameters": {
        "operation": "sendMessage",
        "chatId": "={{ $json.chatId }}",
        "text": "={{ $json.text }}",
        "additionalFields": {"parse_mode": "Markdown"}
      },
      "id": "send-today",
      "name": "📱 Send Today",
      "type": "n8n-nodes-base.telegram",
      "typeVersion": 1.2,
      "position": [1340, 250],
      "credentials": {"telegramApi": {"id": "jOU7JKhtcHMviF47", "name": "Telegram Bot"}}
