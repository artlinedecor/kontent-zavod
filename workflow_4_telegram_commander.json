    {
      "parameters": {
        "jsCode": "const items = $input.all();\nconst chatId = $('🧠 Parse Command').first().json.chatId;\nif (!items.length || !items[0].json.Post_Topic) {\n  return [{ json: { chatId, text: '📊 Hozircha statistika yo\\'q.' } }];\n}\nconst totalViews = items.reduce((s,i) => s + (i.json.Views||0), 0);\nconst totalLikes = items.reduce((s,i) => s + (i.json.Likes||0), 0);\nconst totalShares = items.reduce((s,i) => s + (i.json.Shares||0), 0);\nconst totalSaves = items.reduce((s,i) => s + (i.json.Saves||0), 0);\nconst top = items.filter(i=>i.json.Top_Performing).slice(0,3).map(i=>`  🏆 ${i.json.Post_Topic}: ${i.json.Views} ko'rish`).join('\\n');\nreturn [{ json: { chatId, text: `📊 *STATISTIKA*\\n\\n📈 Jami postlar: ${items.length}\\n👁 Ko'rishlar: ${totalViews.toLocaleString()}\\n❤️ Layklar: ${totalLikes.toLocaleString()}\\n🔄 Ulashishlar: ${totalShares.toLocaleString()}\\n💾 Saqlanganlar: ${totalSaves.toLocaleString()}\\n\\n🏆 *Top postlar:*\\n${top||'Ma\\'lumot yo\\'q'}` } }];"
      },
      "id": "fmt-stats",
      "name": "✏️ Format Stats",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [1120, 400]
