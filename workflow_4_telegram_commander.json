        "jsCode": "const items = $input.all();\nconst chatId = $('🧠 Parse Command').first().json.chatId;\nconst arg = $('🧠 Parse Command').first().json.arg;\nif (!items.length || !items[0].json.id) {\n  return [{ json: { chatId, text: `❌ ${arg}-kun uchun Pending statusdagi topshiriq topilmadi.\\n\\nAvval /plan bilan reja tuzing!`, noRecord: true } }];\n}\nconst r = items[0].json;\nreturn [{ json: { chatId, recordId: r.id, topic: r.Topic_UZ||r.Topic_EN||'Mavzu', style: r.Visual_Style||'', prompt: r.Image_Prompt||'', dayNum: r.Day_Number||arg, noRecord: false } }];"
